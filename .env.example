# ── Upstash Redis (required) ─────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── RPC (optional – defaults to Galactica public RPC) ───────
# RPC_URL=https://galactica-cassiopeia.g.alchemy.com/public

# ── Scanner settings ─────────────────────────────────────────
START_BLOCK=1
END_BLOCK=10000
MAX_BLOCKS_PER_RUN=500
SEED=false

# ── Frontend polling interval (ms) ──────────────────────────
NEXT_PUBLIC_POLL_INTERVAL_MS=30000
